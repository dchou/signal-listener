# Signal Listener - Telegram Trading Signal Listener

# ──────────────────────────────────────────────
# Telethon (for reading public channels as a user account)
# Get api_id and api_hash from https://my.telegram.org → API development tools
# ──────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Channel groups (comma-separated, @ prefix optional)
# CRYPTO: Crypto trading signals
TELEGRAM_CHANNELS_CRYPTO=cheat_brawl_stars

# FOREX: Forex & Gold trading signals
TELEGRAM_CHANNELS_FOREX=Bulls_Signals_Forex_Gold

# INDICATORS: Trading indicators and technical analysis
TELEGRAM_CHANNELS_INDICATORS=cheat_brawl_stars

# ──────────────────────────────────────────────
# Telegram Bot (for sending alerts)
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────
# Local LLM (OpenAI-compatible server: llama.cpp, Ollama, LM Studio, etc.)
# ──────────────────────────────────────────────
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=gemma-2-2b-it

# Signal score threshold (signals with score >= threshold are sent as alerts)
SIGNAL_THRESHOLD=7

# Max age of messages to process (days) - older messages are skipped
MESSAGE_AGE_DAYS=7

# Webhook server port (0 to disable)
WEBHOOK_PORT=8080

# ──────────────────────────────────────────────
# Outgoing webhook (order placement via xchange-line-bot)
# ──────────────────────────────────────────────
WEBHOOK_URL=https://xchange-line.ezcoin.cc/webhook/tradingview
WEBHOOK_SECRET=
WEBHOOK_EXCHANGE=bybit
WEBHOOK_USDT_AMOUNT=50
WEBHOOK_MARKET_TYPE=spot